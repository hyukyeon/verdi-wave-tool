# =============================================================================
# scn_base.lst — Simulation Environment Hierarchy
# =============================================================================
# 각 [section]은 하나의 sim 환경을 정의합니다.
# scn_*.lst 파일의 [BASE] sim = <section명> 으로 참조됩니다.
#
# Keys:
#   top    DUT 최상위 경로 (full path)
#   clk    클럭 신호 (full path)
#   rst    리셋 신호 (full path, active-low)
#   sfr    SFR 베이스 경로 (full path)
#   frame  SFN/frame 카운터 — top. 접두어 사용 가능
#   subfrm 서브프레임 카운터
#   slot   슬롯 카운터
#   sym    심볼 카운터
#
# scn_*.lst에서 신호 경로 작성 규칙:
#   top.X   ->  {top}.X         예) top.pdsch_dl_en
#   sfr.X   ->  {sfr}.X         예) sfr.pdsch_cfg[31:0]
#   clk     ->  {clk}           키워드 직접 사용
#   rst     ->  {rst}
#   frame, subfrm, slot, sym    키워드 직접 사용
# =============================================================================

# -----------------------------------------------------------------------------
# TopSim — LTE 전체 시스템 시뮬레이션
# -----------------------------------------------------------------------------
[topsim_lte]
top    = tb.u_top.u_lte_bb
clk    = tb.sys_clk
rst    = tb.sys_rst_n
sfr    = tb.u_top.u_lte_bb.u_sfr
frame  = top.sfn[9:0]
subfrm = top.subframe_cnt[3:0]
slot   = top.slot_cnt[0]
sym    = top.sym_cnt[3:0]

# -----------------------------------------------------------------------------
# BlockSim — NR SSB 블록 단위 시뮬레이션
# -----------------------------------------------------------------------------
[blocksim_nr_ssb]
top    = tb.u_ssb_top
clk    = tb.clk
rst    = tb.rst_n
sfr    = tb.u_ssb_top.u_sfr
frame  = top.sfn[9:0]
subfrm = top.half_frame[0]
slot   = top.slot_idx[5:0]
sym    = top.sym_idx[3:0]

