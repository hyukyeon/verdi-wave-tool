# =============================================================================
# scn_base.lst -- Simulation Environment Hierarchy
# =============================================================================
# Each [section] defines one simulation environment.
# Referenced from scn_*.lst via:  [BASE]  sim = <section_name>
#
# Keys:
#   top    Full path to the DUT top-level instance
#   clk    Clock signal (full path)
#   rst    Reset signal (full path, active-low)
#   sfr    SFR base path (full path)
#   frame  SFN / frame counter -- may use top. prefix
#   subfrm Subframe counter
#   slot   Slot counter
#   sym    Symbol counter
#
# Signal path resolution rules in scn_*.lst:
#   top.X   ->  {top}.X        e.g. top.pdsch_dl_en
#   sfr.X   ->  {sfr}.X        e.g. sfr.pdsch_cfg[31:0]
#   clk     ->  {clk}          keyword used directly
#   rst     ->  {rst}
#   frame, subfrm, slot, sym   keywords used directly
# =============================================================================

# -----------------------------------------------------------------------------
# TopSim -- LTE full-system simulation
# -----------------------------------------------------------------------------
[topsim_lte]
top    = tb.u_top.u_lte_bb
clk    = tb.sys_clk
rst    = tb.sys_rst_n
sfr    = tb.u_top.u_lte_bb.u_sfr
frame  = top.sfn[9:0]
subfrm = top.subframe_cnt[3:0]
slot   = top.slot_cnt[0]
sym    = top.sym_cnt[3:0]

# -----------------------------------------------------------------------------
# BlockSim -- NR SSB block-level simulation
# -----------------------------------------------------------------------------
[blocksim_nr_ssb]
top    = tb.u_ssb_top
clk    = tb.clk
rst    = tb.rst_n
sfr    = tb.u_ssb_top.u_sfr
frame  = top.sfn[9:0]
subfrm = top.half_frame[0]
slot   = top.slot_idx[5:0]
sym    = top.sym_idx[3:0]

