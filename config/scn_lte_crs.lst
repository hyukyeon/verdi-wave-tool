# =============================================================================
# scn_lte_crs.lst — TopSim LTE CRS Debug Scenario
# =============================================================================
# 목적: LTE Cell-specific Reference Signal (CRS) 동작 검증
#       SFR 설정 → CRS 출력 타이밍 / PDSCH-PDCCH 정렬 / 심볼 마스크 확인
# =============================================================================

[BASE]
sim = topsim_lte

# =============================================================================
# [GROUPS]
# =============================================================================
# 형식:
#   N.     GROUP_NAME   [bg_color]
#   N.M    path         radix   color    [height]   [alias]
#   N.M.K  path         radix   -        [height]   [alias]   (- = group 색 상속)
#
# path 키워드:  clk  rst  frame  subfrm  slot  sym
# path 접두어:  top.X  sfr.X
# =============================================================================

[GROUPS]

1.     TIMING          gray
1.1    clk             bin     gray
1.2    rst             bin     gray
1.3    frame           dec     gray
1.4    subfrm          dec     gray
1.5    slot            dec     gray
1.6    sym             dec     gray

2.     SFR             lightyellow
2.1    sfr.crs_cfg[31:0]         hex    yellow                   CRS_CFG
2.1.1  sfr.crs_cfg[0]            bin    -                        .EN
2.1.2  sfr.crs_cfg[2:1]          dec    -                        .ANT_PORT
2.1.3  sfr.crs_cfg[5:3]          dec    -                        .BW
2.1.4  sfr.crs_cfg[8:6]          dec    -                        .V_SHIFT
2.1.5  sfr.crs_cfg[16:9]         dec    -                        .POWER
2.1.6  sfr.crs_cfg[25:17]        dec    -                        .CELL_ID
2.2    sfr.chan_ctrl[31:0]        hex    yellow                   CHAN_CTRL
2.2.1  sfr.chan_ctrl[0]           bin    -                        .DL_EN
2.2.2  sfr.chan_ctrl[3]           bin    -                        .CRS_EN
2.2.3  sfr.chan_ctrl[30]          bin    -                        .SOFT_RST
2.3    sfr.timing_cfg[31:0]       hex    yellow                   TIMING_CFG
2.3.1  sfr.timing_cfg[11:0]       dec    -                        .TA
2.3.2  sfr.timing_cfg[19:12]      dec    -                        .CRS_OFFSET

3.     CRS             red
3.1    top.crs_en                 bin    red
3.2    top.crs_vld                bin    red
3.3    top.crs_seq[127:0]         hex    red     35
3.4    top.crs_ant_port[1:0]      dec    red
3.5    top.crs_cell_id[8:0]       dec    red
3.6    top.crs_v_shift[2:0]       dec    red
3.7    top.crs_power[7:0]         dec    red
3.8    top.crs_sym_mask[13:0]     bin    red     25               CRS_SYM_MASK

4.     PDSCH           cyan
4.1    top.pdsch_dl_en            bin    cyan
4.2    top.pdsch_dl_vld           bin    cyan
4.3    top.pdsch_dl_data[127:0]   hex    cyan    30
4.4    top.pdsch_dl_mcs[4:0]      dec    cyan
4.5    top.pdsch_dl_rb_num[6:0]   dec    cyan
4.6    top.pdsch_ce_done           bin    cyan

5.     PDCCH           yellow
5.1    top.pdcch_dl_en            bin    yellow
5.2    top.pdcch_dl_vld           bin    yellow
5.3    top.pdcch_dl_dci[39:0]     hex    yellow  25
5.4    top.pdcch_dl_al[2:0]       dec    yellow

# =============================================================================
# [EXPRESSIONS]
# =============================================================================
# 형식:  EN  {expression}  radix  color  alias
# =============================================================================

[EXPRESSIONS]

E1    {top.pdsch_dl_en & top.pdsch_ce_done}   bin    orange    PDSCH_CE_READY
E2    {top.pdcch_dl_en & top.crs_en}          bin    yellow    PDCCH_CRS_ACTIVE

# =============================================================================
# [SCENARIOS]
# =============================================================================
# 형식:
#   SN    scenario-type          (sfr-check | timing | edge-count | frame-sync)
#   SN.M  key = value
#
# key 내 N.M 참조 → [GROUPS]에 정의된 해당 신호의 full path로 자동 변환
# =============================================================================

[SCENARIOS]

# S1: SFR 쓰기 → CRS 출력 레이턴시 측정
S1     sfr-check
S1.1   watch       = 2.1, 2.2, 2.3
S1.2   response    = 3.1
S1.3   max_latency = 8

# S2: CRS 기준 PDSCH/PDCCH 첫 활성화 타이밍 델타
S2     timing
S2.1   reference   = 3.1
S2.2   compare     = 4.2, 5.2

# S3: 채널별 valid 엣지 카운트 (전송 횟수 확인)
S3     edge-count
S3.1   signals     = 3.2, 4.2, 5.2
S3.2   edge        = rising

# S4: LTE 프레임/서브프레임/슬롯 경계 마커
S4     frame-sync
S4.1   standard    = LTE
S4.2   frame_ns    = 10000000
S4.3   subfrm_ns   = 1000000
S4.4   slot_ns     = 500000
S4.5   num_frames  = 8
