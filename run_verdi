#!/bin/bash
# run_verdi - Verdi Signal Restore wrapper
# Usage: run_verdi <SCN> <BASE> <DUMP> [--regen]

set -e

if [ $# -lt 3 ]; then
    echo "Usage: run_verdi <SCN> <BASE> <DUMP> [--regen]"
    echo ""
    echo "  SCN   scenario name  (e.g. lte_crs)"
    echo "  BASE  env name       (e.g. topsim_lte)"
    echo "  DUMP  FSDB file path"
    echo ""
    echo "Available scenarios:"
    python3 "$(dirname "$0")/verdi_wave_tool.py" --list
    exit 1
fi

SCN="$1"
BASE="$2"
DUMP="$3"
REGEN="${4:-}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Generate or Reuse RC file
# FSDB is NOT passed to the generator anymore
python3 "$SCRIPT_DIR/verdi_wave_tool.py" \
    -s "$SCN" -b "$BASE" $REGEN

RC="$SCRIPT_DIR/output/${BASE}_${SCN}.rc"

echo ""
echo "Launching: verdi -ssf $DUMP -sswr $RC"
verdi -ssf "$DUMP" -sswr "$RC"
